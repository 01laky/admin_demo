# Development Environment Variables for Admin Demo
# Copy this file to .env and update values as needed

# Backend API URLs (https when Kestrel uses dev/certs; see dev/README.md)
VITE_API_URL=https://localhost:8001
VITE_API_HTTPS_URL=https://localhost:8001

# Application Configuration
VITE_APP_NAME=Admin Demo
VITE_APP_VERSION=1.0.0

# Development Server Port
VITE_PORT=8081
VITE_DEV_PORT=8082
